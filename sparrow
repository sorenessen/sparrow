#!/usr/bin/env python3
import json, os, sys, time, pathlib, subprocess, threading

# -----------------------------
# Utilities
# -----------------------------

def die(msg, code=2):
    print(msg, file=sys.stderr)
    sys.exit(code)

def find_sparrow_toml(start: pathlib.Path) -> pathlib.Path:
    cur = start.resolve()
    while True:
        p = cur / "sparrow.toml"
        if p.exists():
            return p
        if cur.parent == cur:
            raise FileNotFoundError("sparrow.toml not found")
        cur = cur.parent

def load_toml(path: pathlib.Path) -> dict:
    try:
        import tomllib  # py3.11+
    except Exception:
        die("Python 3.11+ required (tomllib).", 2)
    return tomllib.loads(path.read_text())

def now_ts():
    t = time.time()
    base = time.strftime("%Y%m%d-%H%M%S", time.localtime(t))
    ms = int((t - int(t)) * 1000)
    return f"{base}-{ms:03d}"

def tail_lines(lines, n=50):
    return lines[-n:]

# -----------------------------
# Streaming helpers
# -----------------------------

def stream_pipe(pipe, collector, log_fp, is_err=False):
    for line in iter(pipe.readline, ''):
        if not line:
            break
        collector.append(line.rstrip("\n"))
        if is_err:
            print(line, end="", file=sys.stderr)
        else:
            print(line, end="")
        log_fp.write(line)
        log_fp.flush()
    pipe.close()

# -----------------------------
# Deterministic npm detection
# -----------------------------

def detect_missing_npm_script(stderr_lines, base_dir):
    joined = "\n".join(stderr_lines)
    if 'Missing script:' not in joined:
        return None

    # extract script name
    import re
    m = re.search(r'Missing script:\s+"([^"]+)"', joined)
    if not m:
        return None

    missing = m.group(1)

    pkg = base_dir / "package.json"
    if not pkg.exists():
        return f'npm script "{missing}" not found and no package.json detected.'

    try:
        pkg_data = json.loads(pkg.read_text())
        scripts = pkg_data.get("scripts", {})
        available = ", ".join(sorted(scripts.keys()))
        return (
            f'npm script "{missing}" not found.\n'
            f'Available scripts: {available}\n'
            f'Fix:\n'
            f'- update sparrow.toml [tasks].{missing}, or\n'
            f'- add "{missing}" to package.json scripts.'
        )
    except Exception:
        return None

# -----------------------------
# Core runner
# -----------------------------

def run_task(task, cfg, toml_path):
    workspace = cfg.get("workspace", {})
    root = workspace.get("root", ".")
    base_dir = (toml_path.parent / root).resolve()

    tasks = cfg.get("tasks", {})
    if task not in tasks:
        available = ", ".join(sorted(tasks.keys()))
        die(f"Unknown task '{task}'. Available: {available}", 2)

    commands = tasks[task]
    if not isinstance(commands, list) or not all(isinstance(x, str) for x in commands):
        die(f"Task '{task}' must be an array of strings.", 2)

    runs_dir = base_dir / ".sparrow" / "runs"
    runs_dir.mkdir(parents=True, exist_ok=True)

    ts = now_ts()
    run_json = runs_dir / f"{ts}-{task}.json"
    run_log = runs_dir / f"{ts}-{task}.log"

    run_record = {
        "version": "0.1",
        "workspace": {
            "name": workspace.get("name", base_dir.name),
            "root": str(root),
            "cwd": str(base_dir),
            "sparrow_toml": str(toml_path),
        },
        "task": task,
        "commands": [],
        "result": {"ok": True, "exit_code": 0},
    }

    overall_exit = 0

    with run_log.open("w", encoding="utf-8") as log_fp:
        for i, cmd in enumerate(commands):
            start = time.time()
            log_fp.write(f"$ {cmd}\n")
            log_fp.flush()

            p = subprocess.Popen(
                cmd,
                cwd=str(base_dir),
                shell=True,
                stdout=subprocess.PIPE,
                stderr=subprocess.PIPE,
                text=True,
                bufsize=1
            )

            stdout_lines = []
            stderr_lines = []

            t_out = threading.Thread(target=stream_pipe, args=(p.stdout, stdout_lines, log_fp, False))
            t_err = threading.Thread(target=stream_pipe, args=(p.stderr, stderr_lines, log_fp, True))

            t_out.start()
            t_err.start()

            p.wait()
            t_out.join()
            t_err.join()

            end = time.time()
            exit_code = p.returncode or 0
            overall_exit = exit_code

            run_record["commands"].append({
                "index": i,
                "command": cmd,
                "duration_ms": int((end - start) * 1000),
                "exit_code": exit_code,
                "stdout_tail": tail_lines(stdout_lines),
                "stderr_tail": tail_lines(stderr_lines),
            })

            if exit_code != 0:
                run_record["result"] = {"ok": False, "exit_code": exit_code}

                # Deterministic npm rule
                npm_hint = detect_missing_npm_script(stderr_lines, base_dir)
                if npm_hint:
                    run_record["result"]["hint"] = npm_hint

                break

    run_json.write_text(json.dumps(run_record, indent=2), encoding="utf-8")

    # Summary
    if overall_exit == 0:
        print(f"✓ task {task} (ok)")
    else:
        print(f"✗ task {task} (exit {overall_exit})")
        hint = run_record["result"].get("hint")
        if hint:
            print(hint)
        elif any("exit 1" in line for line in run_record["commands"][-1]["stdout_tail"]):
            print("hint: script exited non-zero (contains 'exit 1').")

    print(f"log:  {run_log}")
    print(f"json: {run_json}")

    return overall_exit

# -----------------------------
# CLI entry
# -----------------------------

def main():
    if len(sys.argv) < 2:
        die("usage: sparrow <command>", 2)

    command = sys.argv[1]

    toml_path = find_sparrow_toml(pathlib.Path.cwd())
    cfg = load_toml(toml_path)

    if command == "run":
        if len(sys.argv) < 3:
            die("usage: sparrow run <task>", 2)
        task = sys.argv[2]
        sys.exit(run_task(task, cfg, toml_path))

    elif command == "up":
        sys.exit(run_task("up", cfg, toml_path))

    elif command == "status":
        workspace = cfg.get("workspace", {})
        tasks = cfg.get("tasks", {})
        print(f"Workspace: {workspace.get('name', toml_path.parent.name)}")
        print(f"Root: {workspace.get('root', '.')}")
        print(f"Tasks: {', '.join(sorted(tasks.keys()))}")
        sys.exit(0)

    else:
        die(f"Unknown command '{command}'", 2)

if __name__ == "__main__":
    main()